# ELEVENLABS_VOICE_LEON=
# ELEVENLABS_VOICE_CHRIS=
# HEYGEN_AVATAR_TIM=       # avatar look ID from: starnews heygen-avatars
# HEYGEN_AVATAR_LEON=
# HEYGEN_AVATAR_CHRIS=
# HEYGEN_TEMPLATE_TIM=     # optional, only if template has audio placeholder
